APP_NAME=HRM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# غيّر هذا إلى عنوان نطاقك في الإنتاج — يُستخدم في روابط إعادة تعيين كلمة المرور
APP_URL=http://localhost:8000
MOBILE_DEEP_LINK_SCHEME=nawatechhrm
FCM_SERVER_KEY=

# CORS — قيود المصادر المسموح بها
# في التطوير: اتركها فارغة (يسمح بكل المصادر)
# في الإنتاج: ALLOWED_ORIGINS=https://app.yourhrm.com,https://admin.yourhrm.com
ALLOWED_ORIGINS=

TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Run `php artisan queue:work` (or repo `scripts/start_queue.sh`) for queued mail/AI jobs.
# Local quick dev: QUEUE_CONNECTION=sync runs jobs immediately without a worker.

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────────────
# MAIL — إعدادات البريد الإلكتروني
# ──────────────────────────────────────────────────────────────────────────────
# التطوير: استخدم 'log' — الرسائل تُكتب في storage/logs/laravel.log
# MAIL_MAILER=log

# Mailtrap (للاختبار) — سجّل على mailtrap.io للحصول على credentials
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password

# Gmail SMTP (للإنتاج)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SCHEME=tls
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your_app_password   # استخدم App Password وليس كلمة المرور الأصلية

# Amazon SES (للإنتاج الاحترافي)
# MAIL_MAILER=ses
# (يتطلب AWS_ACCESS_KEY_ID و AWS_SECRET_ACCESS_KEY أدناه)

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourhrm.com"
MAIL_FROM_NAME="${APP_NAME} HRM"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI Gateway (server-side only)
AI_DEFAULT_PROVIDER=openai
AI_TIMEOUT_SECONDS=25
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
AI_PRICE_OPENAI_GPT4O_MINI_INPUT=0.15
AI_PRICE_OPENAI_GPT4O_MINI_OUTPUT=0.60
AI_PRICE_GEMINI_35_FLASH_INPUT=1.50
AI_PRICE_GEMINI_35_FLASH_OUTPUT=9.00
AI_SLACK_WEBHOOK_URL=

# Stripe billing (optional — without keys, manual/demo activation is used)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# Moyasar billing (Saudi Arabia — amounts in halalas, e.g. 9900 = 99.00 SAR)
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=
MOYASAR_CURRENCY=SAR
MOYASAR_AMOUNT_STARTER=
MOYASAR_AMOUNT_GROWTH=
MOYASAR_AMOUNT_ENTERPRISE=

# stripe | moyasar (first configured provider wins if preferred is unavailable)
BILLING_DEFAULT_PROVIDER=stripe

VITE_APP_NAME="${APP_NAME}"
